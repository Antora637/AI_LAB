void main() {

    TRISB = 0x00;   // PORTB output (Relay connected at RB0)
    TRISD = 0x01;   // RD0 input (Push button)

    PORTB = 0x00;

    while(1)
    {
        if(PORTD.F0 == 1)   // button pressed
        {
            PORTB.F0 = 1;   // Relay ON ? Bulb ON
        }
        else
        {
            PORTB.F0 = 0;   // Relay OFF ? Bulb OFF
        }
    }
}