{
    0x80,  // 10000000
    0x40,  // 01000000
    0x20,  // 00100000
    0x1E,  // 00011110
    0x1E,  // 00011110
    0x20,  // 00100000
    0x40,  // 01000000
    0x80   // 10000000
};

